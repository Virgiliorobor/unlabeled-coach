# ── REQUIRED ─────────────────────────────────────────────────
ANTHROPIC_API_KEY=                  # Claude API key
SESSION_SECRET=                     # 32+ char random string — must be stable across redeploys

# ── STORAGE ──────────────────────────────────────────────────
STORAGE_MODE=local                  # local | github
GITHUB_OWNER=                       # GitHub username or org (github mode only)
GITHUB_REPO=                        # Repository name (github mode only)
GITHUB_TOKEN=                       # Fine-grained token with Contents: Read+Write
GITHUB_BRANCH=main                  # Branch to read/write

# ── EMAIL — RESEND ───────────────────────────────────────────
RESEND_API_KEY=                     # Get from resend.com — free tier 3,000/month
EMAIL_FROM=coach@unlabeled.app      # Sender address (use onboarding@resend.dev for testing)

# ── TELEGRAM ─────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=                 # From @BotFather on Telegram (optional for MVP)

# ── SERVER ───────────────────────────────────────────────────
PORT=3001                           # Railway sets this automatically
NODE_ENV=development

# ── CLAUDE ───────────────────────────────────────────────────
ANTHROPIC_MODEL=claude-opus-4-5     # Override model if needed
ANTHROPIC_MAX_TOKENS=8192
